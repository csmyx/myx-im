{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id AS msg_id,\n            from_uid,\n            to_uid,\n            content,\n            msg_type,\n            EXTRACT(EPOCH FROM created_at)::bigint * 1000 AS \"send_time!\"\n        FROM im_chat_messages\n        WHERE ((from_uid = $1 AND to_uid = $2) OR (from_uid = $2 AND to_uid = $1))\n          AND id < COALESCE($3::bigint, 9223372036854775807)\n        ORDER BY id DESC\n        LIMIT $4\n        ",
