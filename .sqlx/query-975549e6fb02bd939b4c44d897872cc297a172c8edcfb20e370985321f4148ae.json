{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id AS msg_id,\n            from_uid,\n            to_uid,\n            content,\n            msg_type,\n            EXTRACT(EPOCH FROM created_at)::bigint * 1000 AS \"send_time!\"\n        FROM im_chat_messages\n        WHERE to_uid = $1 AND delivered = FALSE\n        ORDER BY id ASC\n        LIMIT $2\n        ",
